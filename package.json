{
	"author": "Luis Blanco <luisblanco1337@gmail.com>",
	"name": "@node-3d/steam-api",
	"version": "0.1.0",
	"description": "Steamworks API bindings for Node.js",
	"license": "MIT",
	"main": "dist/index.js",
	"keywords": [
		"addon",
		"steam",
		"steamworks",
		"steam-api",
		"game",
		"c++",
		"bindings",
		"native",
		"gyp"
	],
	"files": [
		"BUILD.md",
		"dist",
		"install.js",
		"LICENSE",
		"package.json",
		"tsconfig.json"
	],
	"engines": {
		"node": ">=24.13.0",
		"npm": ">=11.6.2"
	},
	"scripts": {
		"postinstall": "node install.js",
		"sdk:ensure": "node scripts/ensure-steamworks-sdk.ts",
		"build:rebuild": "node scripts/ensure-steamworks-sdk.ts && cd src && node-gyp rebuild -j max --silent && node -e \"import('@node-3d/addon-tools').then((m) => m.cpbin('steam-api'))\" && cd .. && node scripts/copy-steam-runtime.ts",
		"build:compile": "node scripts/ensure-steamworks-sdk.ts && cd src && node-gyp build -j max --silent && node -e \"import('@node-3d/addon-tools').then((m) => m.cpbin('steam-api'))\" && cd .. && node scripts/copy-steam-runtime.ts",
		"test:watch": "node --test --watch \"ts/**/*.test.ts\"",
		"test:ci": "node --test \"ts/**/*.test.ts\"",
		"lint:all": "npm run lint:gypi && npm run lint:ts && npm run lint:oxlint",
		"lint:gypi": "node -e \"import('@node-3d/addon-tools').then((m) => m.checkGypi())\"",
		"lint:oxlint": "oxlint .",
		"build:ci": "rslib build",
		"build:watch": "rslib build --watch",
		"lint:ts": "tsgo -p tsconfig.json --noEmit",
		"prepare": "npm run build:ci",
		"format:src": "node -e \"import('@node-3d/addon-tools').then((m) => m.cpclangformat())\" && clang-format -i \"src/cpp/*.cpp\" \"src/cpp/*.hpp\"",
		"format:src:ci": "node -e \"import('@node-3d/addon-tools').then((m) => m.cpclangformat())\" && clang-format --dry-run --Werror \"src/cpp/*.cpp\" \"src/cpp/*.hpp\"",
		"format:ts": "oxfmt -c ./oxfmt.config.ts --no-error-on-unmatched-pattern \"**/*.{js,ts}\"",
		"format:ts:ci": "oxfmt -c ./oxfmt.config.ts --check --no-error-on-unmatched-pattern \"**/*.{js,ts}\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/node-3d/steam-api.git"
	},
	"dependencies": {
		"@node-3d/addon-tools": "^10.0.0",
		"@node-3d/segfault": "^4.0.0"
	},
	"devDependencies": {
		"@rslib/core": "0.23.2",
		"@types/node": "24.13.2",
		"@typescript/native-preview": "7.0.0-dev.20260704.1",
		"clang-format-node": "3.0.7",
		"node-addon-api": "8.9.0",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"tslib": "2.8.1",
		"typescript": "6.0.3"
	},
	"type": "module",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"bugs": {
		"url": "https://github.com/node-3d/node-3d/issues"
	},
	"homepage": "https://github.com/node-3d/node-3d#readme",
	"publishConfig": {
		"access": "public"
	}
}
